# Generate with: openssl rand -hex 32
N8N_ENCRYPTION_KEY=replace_with_32_byte_hex_string

# Groq API key — get from https://console.groq.com (free)
GROQ_API_KEY=gsk_replace_with_your_groq_key

# Supabase — get from https://supabase.com → project → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.replace_with_your_anon_key
